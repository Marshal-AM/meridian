module Meridian.Receivable.RepaymentProof where

import DA.Time

-- | Cryptographic proof-of-payoff observable by supplier (§7.8 Phase 3).
template RepaymentProof
  with
    receivableId : Text
    payer : Party
    payee : Party
    amount : Decimal
    currency : Text
    paidAt : Time
    settlementRef : Text
    supplier : Party
  where
    signatory payer, payee
    observer supplier
